generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

// Obras, livros

model Books {
    id             Int     @id @default(autoincrement())
    title          String
    author         String
    genre          String
    year           Int
    moviment       String
    description_pt String
    //descrição em português
    description_en String
    //descrição em inglês
    plot_pt        String
    // enredo em português
    plot_en        String
    // enredo em inglês
    era_pt         String?
    // contexto histórico em português
    era_en         String?
    // contexto histórico em inglês
    videoURL       String?
    imageURL       String?

    // RELACIONAMENTOS

    characters  Character[]
    quizzes     Quiz[]
    curiosities Curiosity[]

    createdAt DateTime @default(now()) @map("created_at")

    @@map("books")
}

// Personagens

model Character {
    id             Int     @id @default(autoincrement())
    bookId         Int
    name           String
    description_pt String
    //descrição em português
    description_en String
    //descrição em inglês
    role           String?
    imageURL       String?

    // RELACIONAMENTOS

    book Books @relation(fields: [bookId], references: [id], onDelete: Cascade)

    @@map("characters")
}

// Simulados
model Quiz {
    id          Int    @id @default(autoincrement())
    bookId      Int
    question_pt String
    //questão em português
    question_en String
    //questão em inglês

    // Opções em português
    optionA       String
    optionB       String
    optionC       String
    optionD       String
    // Opções em ingles
    optionA_en    String
    optionB_en    String
    optionC_en    String
    optionD_en    String
    correct_answer String // resposta correta

    // FeedBack pedagógico
    explanation_pt String?
    explanation_en String?

    // RELACIONAMENTOS

    book Books @relation(fields: [bookId], references: [id], onDelete: Cascade)

    @@map("quizzes")
}

// Dicas, Redação e Curiosidades
model Curiosity {
    id          Int    @id @default(autoincrement())
    bookId      Int
    category_pt String
    //categoria em português
    category_en String
    //categoria em inglês
    title_pt    String
    //titulo em português
    title_en    String
    //titulo em inglês
    content_pt  String
    //conteúdo em português
    content_en  String
    //conteúdo em inglês

    // RELACIONAMENTOS

    book Books @relation(fields: [bookId], references: [id], onDelete: Cascade)

    @@map("curiosities")
}

// usuarios
model User {
    id           Int    @id @default(autoincrement())
    name         String
    email        String @unique
    passwordHash String

    @@map("users")
}
